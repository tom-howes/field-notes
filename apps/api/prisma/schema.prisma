generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CountryStatus {
  LOCKED
  UNLOCKED
}

enum RoundStatus {
  IN_PROGRESS
  WON
  LOST
}

model Country {
  id        String        @id @default(uuid())
  isoCode   String        @unique @map("iso_code") // ISO 3166-1 alpha-2
  name      String
  region    String?
  status    CountryStatus @default(LOCKED)
  latitude  Float // centroid, for distance-based guess feedback
  longitude Float // centroid, for distance-based guess feedback
  createdAt DateTime      @default(now()) @map("created_at")

  songs           Song[]
  userCollections UserCollection[]
  guessAttempts   GuessAttempt[]

  @@map("countries")
}

model Artist {
  id          String  @id @default(uuid())
  name        String
  nationality String? // supplementary metadata only, not attribution source of truth

  songs Song[]

  @@map("artists")
}

model Song {
  id             String   @id @default(uuid())
  title          String
  artistId       String   @map("artist_id")
  countryId      String   @map("country_id") // recording location = ground truth
  language       String?
  releaseYear    Int?     @map("release_year")
  spotifyTrackId String   @unique @map("spotify_track_id")
  curatorNotes   String?  @map("curator_notes")
  createdAt      DateTime @default(now()) @map("created_at")

  artist          Artist           @relation(fields: [artistId], references: [id])
  country         Country          @relation(fields: [countryId], references: [id])
  guessAttempts   GuessAttempt[]
  userCollections UserCollection[]
  rounds          Round[]

  @@index([countryId])
  @@index([artistId])
  @@map("songs")
}

model User {
  id                    String    @id @default(uuid())
  spotifyUserId         String    @unique @map("spotify_user_id")
  displayName           String    @map("display_name")
  email                 String?
  refreshToken          String?   @map("refresh_token") // Spotify OAuth refresh token; never sent to the client
  accessToken           String?   @map("access_token") // short-lived, cached to avoid refreshing on every request
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  guessAttempts   GuessAttempt[]
  userCollections UserCollection[]
  rounds          Round[]

  @@map("users")
}

model Round {
  id             String      @id @default(uuid())
  userId         String      @map("user_id")
  songId         String      @map("song_id")
  status         RoundStatus @default(IN_PROGRESS)
  currentAttempt Int         @default(1) @map("current_attempt") // 1..6, maps to 5/10/15/20/25/30s
  createdAt      DateTime    @default(now()) @map("created_at")
  completedAt    DateTime?   @map("completed_at")

  user          User           @relation(fields: [userId], references: [id])
  song          Song           @relation(fields: [songId], references: [id])
  guessAttempts GuessAttempt[]

  @@index([userId])
  @@map("rounds")
}

model GuessAttempt {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  roundId          String   @map("round_id")
  songId           String   @map("song_id")
  attemptNumber    Int      @map("attempt_number") // 1..6, maps to 5/10/15/20/25/30s
  clipSeconds      Int      @map("clip_seconds")
  guessedCountryId String?  @map("guessed_country_id")
  correct          Boolean
  createdAt        DateTime @default(now()) @map("created_at")

  user           User     @relation(fields: [userId], references: [id])
  round          Round    @relation(fields: [roundId], references: [id])
  song           Song     @relation(fields: [songId], references: [id])
  guessedCountry Country? @relation(fields: [guessedCountryId], references: [id])

  @@index([userId])
  @@index([roundId])
  @@map("guess_attempts")
}

model UserCollection {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  songId        String   @map("song_id")
  countryId     String   @map("country_id")
  attemptsTaken Int      @map("attempts_taken")
  collectedAt   DateTime @default(now()) @map("collected_at")

  user    User    @relation(fields: [userId], references: [id])
  song    Song    @relation(fields: [songId], references: [id])
  country Country @relation(fields: [countryId], references: [id])

  @@unique([userId, countryId])
  @@index([userId])
  @@map("user_collections")
}
